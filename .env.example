# ═══════════════════════════════════════════════════════════════════════════════
# AI Dev Team Platform — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and platform.env, then fill in your actual values.
# NEVER commit .env or platform.env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

ENVIRONMENT=production
TZ=Europe/Moscow
PUBLIC_BASE_URL=http://your-server-ip-or-domain

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ai_dev_team
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_1
DATABASE_URL=postgresql+psycopg2://postgres:CHANGE_ME_STRONG_PASSWORD_1@postgres:5432/ai_dev_team

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO (S3-compatible storage) ─────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_ROOT_USER=CHANGE_ME_MINIO_ACCESS
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET=ai-dev-team-artifacts

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL_MAIN=gpt-5.4
OPENAI_MODEL_CHEAP=gpt-5-mini
OPENAI_MODEL_COMPUTER_USE=computer-use-preview

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE
GITHUB_ORG=your-github-org
GITHUB_REPO=your-repo-name
GITHUB_DEFAULT_BRANCH=main

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHAR_STRING
ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_48_CHAR_STRING
ADMIN_API_KEY=CHANGE_ME_GENERATE_RANDOM_48_CHAR_STRING
OPERATOR_API_KEY=CHANGE_ME_GENERATE_RANDOM_48_CHAR_STRING
VIEWER_API_KEY=CHANGE_ME_GENERATE_RANDOM_48_CHAR_STRING
INTERNAL_API_KEY=CHANGE_ME_GENERATE_RANDOM_48_CHAR_STRING

# ── Codex ─────────────────────────────────────────────────────────────────────
ENABLE_CODEX=false
CODEX_TIMEOUT_SECONDS=180

# ── Browser Worker ────────────────────────────────────────────────────────────
DEFAULT_DEMO_URL=http://nginx/health

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
